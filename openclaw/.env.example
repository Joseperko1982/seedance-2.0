# Seedance 2.0 — OpenClaw Environment Variables
# Copy this file to .env and fill in your values

# MuAPI.ai API key for Seedance 2.0 video generation
MUAPI_API_KEY=your_muapi_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Thread IDs (from your Telegram group with topics enabled)
# Create a group, enable topics, create 7 threads (one per agent)
# Get thread IDs by forwarding a message from each thread to @getidsbot
TELEGRAM_THREAD_DIRECTOR=
TELEGRAM_THREAD_PROMPTSMITH=
TELEGRAM_THREAD_CINEMATOGRAPHER=
TELEGRAM_THREAD_CASTING=
TELEGRAM_THREAD_MISTAKE=
TELEGRAM_THREAD_SOUND=
TELEGRAM_THREAD_PRODUCER=
