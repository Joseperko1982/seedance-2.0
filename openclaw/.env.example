# Seedance 2.0 — OpenClaw Environment Variables
# Copy this file to .env and fill in your values

# MuAPI.ai API key for Seedance 2.0 video generation
MUAPI_API_KEY=your_muapi_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Group ID (supergroup with topics/forum enabled)
# Get the group ID by adding @getidsbot to your group
# Format: -100xxxxxxxxxx (negative number with -100 prefix)
TELEGRAM_GROUP_ID=-1001234567890

# Telegram Topic/Thread IDs
# Create a supergroup, enable Topics (forum mode), then create 7 topics:
#   Director, Promptsmith, Cinematographer, Casting, Mistake, Sound, Producer
# Get topic IDs by forwarding a message from each topic to @getidsbot
# The General topic is always ID 1
TELEGRAM_TOPIC_DIRECTOR=1
TELEGRAM_TOPIC_PROMPTSMITH=3
TELEGRAM_TOPIC_CINEMATOGRAPHER=5
TELEGRAM_TOPIC_CASTING=7
TELEGRAM_TOPIC_MISTAKE=9
TELEGRAM_TOPIC_SOUND=11
TELEGRAM_TOPIC_PRODUCER=13
